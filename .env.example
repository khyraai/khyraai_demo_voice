# ── Speech-To-Text (Sarvam) ───────────────────────────────────────────────────
SARVAM_API_KEY=your_sarvam_api_key

# ── LLM (OpenRouter) ───────────────────────────────────────────────────────────
# Provider: "openrouter" (default) or "sarvam"
# Switch to sarvam to test Sarvam 105B; switch back to openrouter instantly.
LLM_PROVIDER=openrouter

OPENROUTER_API_KEY=your_openrouter_api_key
# Optional: comma-separated keys for round-robin pool
# OPENROUTER_API_KEYS=key1,key2,key3

LLM_MODEL=meta-llama/llama-3.3-70b-instruct

# Sarvam 105B (used when LLM_PROVIDER=sarvam — reuses SARVAM_API_KEY above)
LLM_MODEL_SARVAM=sarvam-105b

LLM_MAX_CONCURRENT_PER_KEY=5
LLM_MAX_RETRIES=2
LLM_RETRY_DELAY_SEC=0.3

# ── Text-To-Speech (Sarvam Bulbul) ────────────────────────────────────────────
# Model used for collect mode (short texts / fallback)
SARVAM_TTS_MODEL=bulbul:v2
# Pace: 0.8 (slow) – 1.2 (fast), default 0.95
SARVAM_TTS_PACE=0.95

# ── Demo Voices ───────────────────────────────────────────────────────────────
# Configure the 10 voices shown in the UI.
# speaker values: any valid Sarvam Bulbul v3 speaker slug
DEMO_VOICE_1_NAME=Priya
DEMO_VOICE_1_SPEAKER=priya

DEMO_VOICE_2_NAME=Kavya
DEMO_VOICE_2_SPEAKER=kavya

DEMO_VOICE_3_NAME=Neha
DEMO_VOICE_3_SPEAKER=neha

DEMO_VOICE_4_NAME=Simran
DEMO_VOICE_4_SPEAKER=simran

DEMO_VOICE_5_NAME=Pooja
DEMO_VOICE_5_SPEAKER=pooja

DEMO_VOICE_6_NAME=Rahul
DEMO_VOICE_6_SPEAKER=rahul

DEMO_VOICE_7_NAME=Rohan
DEMO_VOICE_7_SPEAKER=rohan

DEMO_VOICE_8_NAME=Aditya
DEMO_VOICE_8_SPEAKER=aditya

DEMO_VOICE_9_NAME=Amit
DEMO_VOICE_9_SPEAKER=amit

DEMO_VOICE_10_NAME=Ratan
DEMO_VOICE_10_SPEAKER=ratan

# ── Demo Session Limits ────────────────────────────────────────────────────────
DEMO_SESSION_TIMEOUT_SEC=300
DEMO_MAX_TURNS=20
