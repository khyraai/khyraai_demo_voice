# ── Speech-To-Text (Sarvam) ───────────────────────────────────────────────────
SARVAM_API_KEY=your_sarvam_api_key

# ── LLM (Groq) ────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key
# Optional: comma-separated keys for round-robin pool
# GROQ_API_KEYS=key1,key2,key3

LLM_MODEL=llama-3.3-70b-versatile
LLM_MAX_CONCURRENT_PER_KEY=5
LLM_MAX_RETRIES=2
LLM_RETRY_DELAY_SEC=0.3

# ── Text-To-Speech (Sarvam Bulbul) ────────────────────────────────────────────
# Model used for collect mode (short texts / fallback)
SARVAM_TTS_MODEL=bulbul:v2
# Pace: 0.8 (slow) – 1.2 (fast), default 0.95
SARVAM_TTS_PACE=0.95

# ── Demo Voices ───────────────────────────────────────────────────────────────
# Configure the 4 voices shown in the UI.
# speaker values: any valid Sarvam Bulbul speaker slug
DEMO_VOICE_1_NAME=Priya
DEMO_VOICE_1_SPEAKER=priya

DEMO_VOICE_2_NAME=Kavya
DEMO_VOICE_2_SPEAKER=kavya

DEMO_VOICE_3_NAME=Rahul
DEMO_VOICE_3_SPEAKER=rahul

DEMO_VOICE_4_NAME=Rohan
DEMO_VOICE_4_SPEAKER=rohan

# ── Demo Session Limits ────────────────────────────────────────────────────────
DEMO_SESSION_TIMEOUT_SEC=300
DEMO_MAX_TURNS=20
